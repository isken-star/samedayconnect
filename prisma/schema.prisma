generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VanType {
  SMALL
  MEDIUM
  LARGE
}

enum JobType {
  SAME_DAY
  DIRECT
}

enum ReadyMode {
  READY_NOW
  PREBOOK
}

enum CourierAvailabilityStatus {
  AVAILABLE
  BUSY
  OFF
}

enum CourierJobStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  COMPLETED
}

enum BookingDraftStatus {
  DRAFT
  CHECKOUT_CREATED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum BookingStopKind {
  COLLECTION
  DELIVERY
}

enum PaymentProvider {
  STRIPE
}

enum PaymentStatus {
  PENDING
  CHECKOUT_CREATED
  SUCCEEDED
  FAILED
  CANCELLED
}

model Courier {
  id                         String         @id @default(uuid())
  slug                       String         @unique
  businessName               String
  displayName                String
  bio                        String
  phone                      String?
  email                      String?        @unique
  baseArea                   String
  basePostcode               String?
  vanType                    VanType
  vanPayloadKg               Int
  insuranceGoodsInTransit    Boolean
  insurancePublicLiability   Boolean
  profilePhotoUrl            String?
  vanPhotoUrl                String?
  isActive                   Boolean        @default(true)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  quoteRequests              QuoteRequest[]
  sessions                   CourierSession[]
  magicLinkTokens            MagicLinkToken[]
  availability               CourierAvailability?
  jobs                       Job[]
  bookings                   Booking[]

  @@index([isActive])
}

model QuoteRequest {
  id                 String        @id @default(uuid())
  courierId          String?
  collectionPostcode String
  deliveryPostcodes  String[]
  readyMode          ReadyMode
  collectionDateTime DateTime?
  selectedVanType    VanType
  createdAt          DateTime      @default(now())
  courier            Courier?      @relation(fields: [courierId], references: [id], onDelete: SetNull)
  quoteResults       QuoteResult[]
  bookingDrafts      BookingDraft[]
  bookings           Booking[]

  @@index([courierId])
  @@index([createdAt])
}

model QuoteResult {
  id               String       @id @default(uuid())
  quoteRequestId   String
  jobType          JobType
  miles            Float
  runningMilesFee  Decimal      @default(0) @db.Decimal(10, 2)
  perMileRate      Decimal      @db.Decimal(10, 2)
  distanceCharge   Decimal      @db.Decimal(10, 2)
  minimumCharge    Decimal      @db.Decimal(10, 2)
  minimumApplied   Boolean
  extraStopsCount  Int
  stopsFee         Decimal      @db.Decimal(10, 2)
  congestionApplied Boolean
  congestionFee    Decimal      @db.Decimal(10, 2)
  total            Decimal      @db.Decimal(10, 2)
  createdAt        DateTime     @default(now())
  quoteRequest     QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)

  @@index([quoteRequestId])
  @@index([jobType])
}

model BookingDraft {
  id                    String             @id @default(uuid())
  quoteRequestId        String
  jobTypeChosen         JobType
  communityShareOptIn   Boolean
  quotedTotal           Decimal            @db.Decimal(10, 2)
  currency              String             @default("GBP")
  customerName          String?
  customerEmail         String?
  customerPhone         String?
  collectionAddressLine1 String?
  collectionContactName String?
  collectionContactPhone String?
  notes                 String?
  reference             String?
  status                BookingDraftStatus @default(DRAFT)
  checkoutStartedAt     DateTime?
  completedAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  quoteRequest          QuoteRequest       @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  draftStops            BookingDraftStop[]
  payments              Payment[]
  booking               Booking?

  @@index([quoteRequestId])
  @@index([status])
}

model BookingDraftStop {
  id            String          @id @default(uuid())
  bookingDraftId String
  sequence      Int
  kind          BookingStopKind
  postcode      String
  addressLine1  String?
  contactName   String?
  contactPhone  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bookingDraft  BookingDraft    @relation(fields: [bookingDraftId], references: [id], onDelete: Cascade)

  @@unique([bookingDraftId, sequence])
  @@index([bookingDraftId, kind])
}

model Booking {
  id                  String        @id @default(uuid())
  bookingDraftId      String        @unique
  quoteRequestId      String
  courierId           String?
  jobTypeChosen       JobType
  status              BookingStatus @default(CONFIRMED)
  communityShareOptIn Boolean
  quotedTotal         Decimal       @db.Decimal(10, 2)
  currency            String        @default("GBP")
  customerName        String
  customerEmail       String
  customerPhone       String?
  notes               String?
  reference           String?
  paidAt              DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  bookingDraft        BookingDraft  @relation(fields: [bookingDraftId], references: [id], onDelete: Cascade)
  quoteRequest        QuoteRequest  @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  courier             Courier?      @relation(fields: [courierId], references: [id], onDelete: SetNull)
  stops               BookingStop[]
  payments            Payment[]
  job                 Job?

  @@index([quoteRequestId])
  @@index([courierId])
  @@index([status])
}

model BookingStop {
  id           String          @id @default(uuid())
  bookingId    String
  sequence     Int
  kind         BookingStopKind
  postcode     String
  addressLine1 String
  contactName  String
  contactPhone String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  booking      Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, sequence])
  @@index([bookingId, kind])
}

model Payment {
  id                     String          @id @default(uuid())
  bookingDraftId         String
  bookingId              String?
  provider               PaymentProvider
  status                 PaymentStatus   @default(PENDING)
  amount                 Decimal         @db.Decimal(10, 2)
  currency               String          @default("GBP")
  stripeCheckoutSessionId String?        @unique
  stripePaymentIntentId  String?         @unique
  paidAt                 DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  bookingDraft           BookingDraft    @relation(fields: [bookingDraftId], references: [id], onDelete: Cascade)
  booking                Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([bookingDraftId])
  @@index([bookingId])
  @@index([status])
}

model JoinApplication {
  id                 String   @id @default(uuid())
  fullName           String
  businessName       String
  email              String
  phone              String
  areasCovered       String
  vanType            VanType
  insuranceConfirmed Boolean
  message            String?
  createdAt          DateTime @default(now())

  @@index([createdAt])
}

model CourierSession {
  id               String   @id @default(uuid())
  courierId        String
  sessionTokenHash String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @default(now())
  courier          Courier  @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([expiresAt])
}

model MagicLinkToken {
  id        String   @id @default(uuid())
  courierId String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  requestIp String?
  courier   Courier  @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([expiresAt])
  @@index([usedAt])
}

model CourierAvailability {
  courierId  String                    @id
  status     CourierAvailabilityStatus @default(AVAILABLE)
  busyUntil  DateTime?
  updatedAt  DateTime                  @updatedAt
  courier    Courier                   @relation(fields: [courierId], references: [id], onDelete: Cascade)
}

model Job {
  id                 String           @id @default(uuid())
  bookingId          String?          @unique
  courierId          String
  status             CourierJobStatus @default(PENDING)
  collectionPostcode String
  deliveryPostcodes  String[]
  vanType            VanType
  jobType            JobType
  readyAt            DateTime?
  quotedTotal        Decimal          @db.Decimal(10, 2)
  createdAt          DateTime         @default(now())
  acceptedAt         DateTime?
  completedAt        DateTime?
  booking            Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  courier            Courier          @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId, status])
  @@index([createdAt])
  @@index([readyAt])
}
